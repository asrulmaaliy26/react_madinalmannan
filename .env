VITE_PROFILE_DESC="Lembaga pendidikan agama Islam yang berdedikasi untuk mencetak generasi muda yang cerdas, berwawasan islami, dan berakhlak qurani."
VITE_PROFILE_IMAGE="/pengurus.jpeg"

# About Page Configuration
VITE_ABOUT_VISI="Terwujudnya insan yang beriman, bertaqwa, dan berakhlakul karimah"
VITE_ABOUT_MISI='["Membekali santri dalam ilmu agama ala Ahlussunnah Wal Jamaah", "Menanamkan nilai-nilai syariah dalam kehidupan sehari-hari", "Mendidik dan membimbing santri dalam mengimplementasikan Al Quran dan Sunnah", "Mencetak generasi muda yang cerdas, moderat, intelektual, berwawasan islami, dan berakhlak qurani"]'
VITE_ABOUT_HISTORY="Madrasah Diniyah Takmiliyah Awwaliyah (MDTA) Al-Hidayah secara resmi beroperasi di bawah naungan Yayasan Pondok Pesantren Al Mannan Kauman. Didirikannya lembaga ini dilatarbelakangi oleh kebutuhan mendesak akan institusi pendidikan ilmu agama yang terstruktur bagi generasi muda sebagai benteng spiritual di era modern. Berlokasi strategis di Jl. KH. Hasyim Asyari 52 Gg 3, Desa Kauman, Tulungagung, MDTA Al-Hidayah menawarkan lingkungan belajar yang sangat kondusif. Kami menerapkan sistem pendidikan yang memadukan kedisiplinan kurikulum ala Ahlussunnah Wal Jamaah dengan standar kontemporer, dengan fokus utama pada pemahaman syariah, implementasi Al-Quran dan Sunnah, serta penekanan pada akhlakul karimah."
VITE_ABOUT_STRUKTUR='{"pimpinan": "Kepala Madrasah", "nama": "Anma Muniri S. Hum.", "staff": [{"role": "Penanggung Jawab", "name": "Agus Amal Sabda Tama"}, {"role": "Penasehat", "name": "KH. Ahmad Nasukhi"}, {"role": "Sekretaris", "name": "Laila Hidayatil Muslikhah"}, {"role": "Bendahara", "name": "Nilna Muna"}, {"role": "Waka Kurikulum", "name": "Ishthifaul Ashfia"}, {"role": "Waka Kesiswaan", "name": "Ibnu Rofi Ishomudin"}]}'
VITE_ABOUT_IMAGE="/gedungdepan.jpg"

