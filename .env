VITE_HOME_TESTIMONIALS='[{"text":"Sebaik-baik kalian adalah yang mempelajari Al-Quran dan mengajarkannya.","author":"Hadits Riwayat Bukhari","image":"/banner1.jpeg"},{"text":"Al-Quran adalah cahaya bagi hati yang beriman.","author":"Pepatah Islami","image":"/banner1.jpeg"},{"text":"Didiklah anakmu sesuai zamannya, karena mereka hidup bukan di zamanmu.","author":"Ali bin Abi Thalib","image":"/banner1.jpeg"}]'
